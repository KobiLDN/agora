<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#141414">

    <!-- top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1e1e1e"
        android:padding="6dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏛️ Agora"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <Button
            android:id="@+id/bridgeButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="Start"
            android:textSize="12sp"
            android:backgroundTint="#4a6cf7"
            android:textColor="#ffffff" />
    </LinearLayout>

    <!-- tab switcher -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1a1a1a">

        <Button
            android:id="@+id/tabDeepSeek"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DeepSeek"
            android:textSize="12sp"
            android:textColor="#e0e0e0" />

        <Button
            android:id="@+id/tabClaude"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Claude"
            android:textSize="12sp"
            android:textColor="#e0e0e0" />

        <Button
            android:id="@+id/tabLog"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Log"
            android:textSize="12sp"
            android:textColor="#e0e0e0" />
    </LinearLayout>

    <!-- content area: two webviews + a log scroll, visibility toggled -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webDeepSeek"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <WebView
            android:id="@+id/webClaude"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="#141414"
            android:padding="10dp">

            <TextView
                android:id="@+id/logText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#d0d0d0"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />
        </ScrollView>
    </FrameLayout>

    <!-- interject bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1e1e1e"
        android:padding="6dp">

        <EditText
            android:id="@+id/interjectInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Interject as [Human]…"
            android:textColorHint="#666666"
            android:textColor="#e0e0e0"
            android:background="#141414"
            android:padding="8dp"
            android:maxLines="3"
            android:inputType="textMultiLine|textCapSentences" />

        <Spinner
            android:id="@+id/targetSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="Send"
            android:textSize="12sp"
            android:backgroundTint="#4a6cf7"
            android:textColor="#ffffff" />
    </LinearLayout>
</LinearLayout>
