{
  "manifest_version": 3,
  "name": "AI Conversation Bridge",
  "version": "1.0.0",
  "description": "Make DeepSeek and Claude talk to each other",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://claude.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*", "https://claude.ai/*"],
      "exclude_matches": ["https://claude.ai/code/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["inject.js"],
    "matches": ["https://chat.deepseek.com/*", "https://claude.ai/*"]
  }]
}
